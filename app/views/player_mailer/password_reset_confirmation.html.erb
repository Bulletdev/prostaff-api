<% content_for :preheader do %>
  Sua senha ArenaBR foi redefinida com sucesso. Se não foi você, contate o suporte imediatamente.
<% end %>

<% content_for :category_bar do %>
  &#9670; ArenaBR &middot; Senha Redefinida
<% end %>

<div style="font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:9px;color:rgba(0,211,100,0.6);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
  Confirmação de segurança &middot; ArenaBR
</div>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;color:#FFFFFF;margin:0 0 6px;line-height:1.6;font-weight:500;">
  Olá, <strong style="color:#C89B3C;"><%= @player.real_name.presence || @player.summoner_name %></strong>.
</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#bcc4cf;margin:0 0 24px;line-height:1.6;">
  A senha da sua conta ArenaBR (<strong style="color:#FFFFFF;"><%= @player.player_email %></strong>) foi redefinida com sucesso.
</p>

<!-- Warning callout -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:rgba(255,68,68,0.08);margin-bottom:28px;">
  <tr>
    <td style="width:3px;background-color:#FF4444;font-size:0;line-height:0;">&nbsp;</td>
    <td style="padding:14px 18px;">
      <p style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#FF6B6B;font-weight:600;margin:0;line-height:1.5;">
        <strong>Não foi você?</strong> Entre em contato com o suporte imediatamente em
        <a href="mailto:hello@prostaff.gg" style="color:#FF6B6B;text-decoration:underline;">hello@prostaff.gg</a>.
        Sua conta pode ter sido comprometida.
      </p>
    </td>
  </tr>
</table>

<!-- CTA button -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center">
      <!--[if mso]>
      <v:rect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word"
        href="<%= @frontend_url %>/login" style="height:46px;v-text-anchor:middle;width:240px;" stroke="t" strokecolor="#C89B3C" fillcolor="#C89B3C">
        <w:anchorlock/>
        <center style="color:#0A0E1A;font-family:Verdana,sans-serif;font-size:12px;font-weight:700;letter-spacing:2px;">ACESSAR MINHA CONTA</center>
      </v:rect>
      <![endif]-->
      <!--[if !mso]><!-->
      <a href="<%= @frontend_url %>/login"
         style="background-color:#C89B3C;color:#0A0E1A;display:inline-block;font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:12px;font-weight:700;line-height:1;padding:16px 38px;text-decoration:none;letter-spacing:2px;text-transform:uppercase;border:1px solid #C89B3C;">
        Acessar Minha Conta
      </a>
      <!--<![endif]-->
    </td>
  </tr>
</table>

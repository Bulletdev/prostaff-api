<% content_for :preheader do %>
  Sua conta ProStaff está pronta. Acesse a plataforma de gestão de esports.
<% end %>

<% content_for :category_bar do %>
  &#9670; Bem-vindo &middot; Conta Criada
<% end %>

<div style="font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:9px;color:rgba(200,155,60,0.5);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
  Acesso liberado
</div>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;color:#FFFFFF;margin:0 0 6px;line-height:1.6;font-weight:500;">
  Olá, <strong style="color:#C89B3C;"><%= @user.full_name || 'jogador' %></strong>.
</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#bcc4cf;margin:0 0 24px;line-height:1.6;">

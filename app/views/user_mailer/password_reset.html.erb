<% content_for :preheader do %>
  Link para redefinição de senha da sua conta ProStaff — válido por <%= @expires_in %> minutos.
<% end %>

<% content_for :category_bar do %>
  &#9670; Segurança &middot; Redefinição de Senha
<% end %>

<div style="font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:9px;color:rgba(200,155,60,0.5);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
  Solicitação de acesso
</div>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;color:#FFFFFF;margin:0 0 6px;line-height:1.6;font-weight:500;">
  Olá, <strong style="color:#C89B3C;"><%= @user.full_name || 'usuário' %></strong>.
</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#bcc4cf;margin:0 0 28px;line-height:1.6;">
  Recebemos uma solicitação de redefinição de senha para sua conta ProStaff (<strong style="color:#FFFFFF;"><%= @user.email %></strong>).
</p>

<!-- CTA button -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
  <tr>
    <td align="center">
      <!--[if mso]>
      <v:rect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word"
        href="<%= @reset_url %>" style="height:46px;v-text-anchor:middle;width:220px;" stroke="t" strokecolor="#C89B3C" fillcolor="#C89B3C">
        <w:anchorlock/>
        <center style="color:#0A0E1A;font-family:Verdana,sans-serif;font-size:12px;font-weight:700;letter-spacing:2px;">REDEFINIR SENHA</center>
      </v:rect>
      <![endif]-->
      <!--[if !mso]><!-->
      <%# @reset_url e validada no UserMailer#password_reset como URI::HTTP antes de ser atribuida %>
      <a href="<%= @reset_url %>" <%# nosemgrep: ruby.rails.security.audit.xss.templates.var-in-href.var-in-href %>
         style="background-color:#C89B3C;color:#0A0E1A;display:inline-block;font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:12px;font-weight:700;line-height:1;padding:16px 38px;text-decoration:none;letter-spacing:2px;text-transform:uppercase;border:1px solid #C89B3C;">
        Redefinir Senha
      </a>
      <!--<![endif]-->
    </td>
  </tr>
</table>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:rgba(188,196,207,0.5);margin:0 0 6px;text-align:center;">Ou copie e cole este link:</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#C89B3C;word-break:break-all;margin:0 0 24px;text-align:center;"><%= @reset_url %></p>

<!-- Expiry warning -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:rgba(255,68,68,0.08);margin-bottom:24px;">
  <tr>
    <td style="width:3px;background-color:#FF4444;font-size:0;line-height:0;">&nbsp;</td>
    <td style="padding:12px 16px;">
      <p style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#FF6B6B;font-weight:600;margin:0;">
        Este link expira em <strong><%= @expires_in %> minutos</strong>.
      </p>
    </td>
  </tr>
</table>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:rgba(188,196,207,0.5);margin:0;text-align:center;">
  Se você não solicitou a redefinição de senha, ignore este e-mail. Sua senha não será alterada.
</p>

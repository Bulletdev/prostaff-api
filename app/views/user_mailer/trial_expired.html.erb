<% content_for :preheader do %>
  O período de teste da <%= @organization&.name %> encerrou. Assine para continuar com acesso completo.
<% end %>

<% content_for :category_bar do %>
  &#9670; Trial &middot; Período Encerrado
<% end %>

<div style="font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:9px;color:rgba(255,68,68,0.7);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
  Acesso suspenso
</div>

<p style="font-family:Arial,Helvetica,sans-serif;font-size:16px;color:#FFFFFF;margin:0 0 6px;line-height:1.6;font-weight:500;">
  Olá, <strong style="color:#C89B3C;"><%= @user.full_name || 'usuário' %></strong>.
</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#bcc4cf;margin:0 0 10px;line-height:1.6;">
  O período de teste de 14 dias da organização <strong style="color:#FFFFFF;"><%= @organization&.name %></strong> encerrou.
  O acesso à plataforma foi <strong style="color:#FF4444;">suspenso</strong>.
</p>
<p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#bcc4cf;margin:0 0 24px;line-height:1.6;">
  Assine o ProStaff para continuar gerenciando seu time e acessar todos os recursos:
</p>

<!-- Features list card -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0A0E1A;border:1px solid rgba(200,155,60,0.5);margin-bottom:28px;">
  <tr>
    <td style="padding:22px 26px;">
      <div style="font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:8px;color:rgba(200,155,60,0.5);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">Recursos disponíveis na assinatura</div>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="padding:5px 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#bcc4cf;">
            <span style="color:#C89B3C;margin-right:8px;">&#9670;</span> Estatísticas de jogadores e histórico de partidas
          </td>
        </tr>
        <tr>
          <td style="padding:5px 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#bcc4cf;">
            <span style="color:#C89B3C;margin-right:8px;">&#9670;</span> VOD review com anotações em timestamps
          </td>
        </tr>
        <tr>
          <td style="padding:5px 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#bcc4cf;">
            <span style="color:#C89B3C;margin-right:8px;">&#9670;</span> Scouting e análise de talentos
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

